# ---------- Issue #55: capture(regex; "g") must yield every match ----------

[capture("(?<n>\\d+)"; "g")]
"a1 b2 c3"

[capture("(?<n>\\d+)"; "g")]
"1,2,3"

capture("(?<n>\\d+)"; "g")
"1 2 3"

capture("(?<n>\\d+)")
"1,2,3"

