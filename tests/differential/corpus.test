# ---------- Issue #41: unique_by(f) must sort by f ----------

unique_by(.)
[3,1,2]

unique_by(.)
[1,2,3,null]

unique_by(tostring)
[null,1,2,3]

unique_by(.)
[1,"a",null,2]

unique_by(.a)
