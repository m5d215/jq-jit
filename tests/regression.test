if .a > 1 then .a else .b end
{"a":"x","b":2}
"x"

# Issue #161: cond_chain general (elif) path
if .a > 1 then "h" elif .a > 0 then "m" else "l" end
{"a":"x","b":2,"c":3}
"h"

