try (. + 1) catch .
"abcdefghijkl"
"string (\"abcdefghijkl\") and number (1) cannot be added"

# Issue #465: 15-byte string triggers truncation
try (. + 1) catch .
"abcdefghijklm"
"string (\"abcdefghij...) and number (1) cannot be added"

# Issue #465: errdesc truncates arrays
