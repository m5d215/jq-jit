false
[]

# Counter-case: object with matching string. Fast path stays hot.
(select(.a == "hello")) | (.a)
{"a":"hello"}
"hello"

# Counter-case: object with non-matching string — select rejects.
[((select(.a == "")) | (.a))]
{"a":"x"}
[]

