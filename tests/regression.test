# the `select(.f cmp N) | {computed_remap}` shape.
[((select(.a <= 0)) | ({a: (.a + .b)}))?]
[]
[]

# null input: select passes (null<=0 is true), .a+.b is null+null
# = null, output `{"a":null}`.
(select(.a <= 0)) | ({a: (.a + .b)})
null
{"a":null}

# Type mismatch in remap pair: jq raises, fast path now bails to
# generic so the error reaches stdout.
