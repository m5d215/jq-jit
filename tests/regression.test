# Issue #127: .a on a number errors instead of returning null
.a
1

# Issue #127: .a on a string errors
.a
"str"

# Issue #127: .a on a boolean errors
.a
true

# Issue #127: .a on an array errors
.a
[1,2]

# Issue #127: .["a"] on a number errors (bracket-index form)
.["a"]
1

# Issue #127: .a.b on a number errors (nested access bails to generic)
.a.b
1

# Issue #127: .a.b on an object with non-object intermediate still errors
.a.b
{"a":1}

# Issue #127: .a on null still returns null
.a
null
null

# Issue #127: .a on an object still returns the field
.a
{"a":42}
