# Issue #108: isfinite of infinity is false
infinite | isfinite
null
false

# Issue #108: isfinite of regular number is true
1 | isfinite
null
true

# Issue #108: isfinite of non-number is false
"x" | isfinite
null
false

# Issue #102: gen body with compound arithmetic must not collapse the array
[range(5) | . * 2] | .[0]
null
0

# Issue #102: negative endpoint with arithmetic body
[range(5) | . + 1] | .[-1]
null
5

# Issue #102: comma generator with arithmetic body
[1,2,3 | . * 2] | .[0]
null
2

# Issue #102: arithmetic body with addition still selects index 0
[range(5) | . + 1] | .[0]
null
1

# Issue #111: rtrimstr("") yields "" (jq slice -0 quirk)
rtrimstr("")
"hello"
""

# Issue #111: rtrimstr("") on empty string stays ""
rtrimstr("")
""
""

# Issue #111: ltrimstr("") still returns input unchanged
ltrimstr("")
"hello"
"hello"

# Issue #111: rtrimstr with non-empty suffix still works
rtrimstr("lo")
"hello"
"hel"

# Issue #112: ascii/0 must not be registered (jq 1.8.1 has no such builtin)
[builtins[] | select(. == "ascii/0")]
null
[]

# Issue #112: ascii_downcase/0 must stay registered
builtins | any(. == "ascii_downcase/0")
null
true

# Issue #112: ascii_upcase/0 must stay registered
builtins | any(. == "ascii_upcase/0")
null
true

# Issue #118: finites/0 keeps finite numbers, drops non-numbers and infinities
[1,"a",null,[1],{}] | map(.. | finites?)
null
[1,1]

# Issue #118: normals/0 keeps only normal numbers (drops 0, NaN, inf, non-numbers)
[0,1,2] | map(normals)
null
[1,2]

# Issue #118: finites/0 and normals/0 must be registered in builtins
builtins | any(. == "finites/0")
null
true

# Issue #118: normals/0 registered
builtins | any(. == "normals/0")
null
true

