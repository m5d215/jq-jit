# Issue #161: missing field is null, falls into else branch
if .a > 1 then "h" else "l" end
{}
"l"

# Issue #161: explicit null compares as < number
if .a > 1 then "h" else "l" end
{"a":null}
"l"

# Issue #161: arith chain comparison falls through on non-numeric field
