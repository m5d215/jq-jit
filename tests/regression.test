{"x":42}
[]

# `?`-wrapped: missing field — generic null|test raises type error.
[ (select(.x | test("^h")))? ]
{"y":1}
[]

# `?`-wrapped: non-object input — generic raises indexing error.
[ (select(.x | test("^h")))? ]
"plain"
[]

